{
  "extends": "./tsconfig.build.json",
  "include": [
    "packages",
    "types",
    "scripts",
    "examples",
    "rollup.config.ts"
  ],
  "exclude": [],
  "compilerOptions": {
    "allowJs": false,
    "paths": {
