{
  "name": "@edgestore/react",
  "version": "0.7.0",
  "description": "Upload files with ease from React/Next.js",
  "homepage": "https://edgestore.dev",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/edgestorejs/edgestore.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Ravi <me@ravi.com>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "react",
    "nodejs",
    "nextjs",
    "upload",
    "file",
    "image",
    "cdn",
    "edgestore",
    "edge-store"
  ],
  "scripts": {
    "build": "rollup --config rollup.config.ts --configPlugin rollup-plugin-swc3",
    "dev": "pnpm build --watch",
    "codegen:entrypoints": "tsx entrypoints.script.ts",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint --cache --report-unused-disable-directives src"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "default": "./dist/errors/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js",
      "default": "./dist/shared/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "package.json",
    "errors",
    "shared",
    "utils",
    "!**/*.test.*",
    "!**/__tests__"
  ],
  "dependencies": {
    "@edgestore/shared": "0.7.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "25.0.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "^29.1.1",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "zod": "3.25.76"
  },
  "gitHead": "a223c4cb8df50e6b64f9db5dc2daf93848748da9"
}
