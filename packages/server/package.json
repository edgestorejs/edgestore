{
  "name": "@edgestore/server",
  "version": "0.7.0",
  "description": "Upload files with ease from React/Next.js",
  "homepage": "https://edgestore.dev",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/edgestorejs/edgestore.git",
    "directory": "packages/server"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Ravi <me@ravi.com>",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "keywords": [
    "react",
    "nodejs",
    "nextjs",
    "upload",
    "file",
    "image",
    "cdn",
    "edgestore",
    "edge-store"
  ],
  "scripts": {
    "build": "rollup --config rollup.config.ts --configPlugin rollup-plugin-swc3",
    "dev": "pnpm build --watch",
    "codegen:entrypoints": "tsx entrypoints.script.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:smoke:dev": "TEST_ENV=dev vitest run --config vitest.smoke.config.ts",
    "test:smoke:prod": "TEST_ENV=prod vitest run --config vitest.smoke.config.ts",
    "test:smoke:adapter": "vitest run --config vitest.smoke.config.ts src/adapters/edgestore.smoke.test.ts",
    "test:smoke:client": "vitest run --config vitest.smoke.config.ts src/core/client/edgestore.smoke.test.ts",
    "test:smoke:errors": "vitest run --config vitest.smoke.config.ts src/core/sdk/edgestore.errors.smoke.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint --cache --report-unused-disable-directives src"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters/astro": {
      "import": "./dist/adapters/astro/index.mjs",
      "require": "./dist/adapters/astro/index.js",
      "default": "./dist/adapters/astro/index.js"
    },
    "./adapters/express": {
      "import": "./dist/adapters/express/index.mjs",
      "require": "./dist/adapters/express/index.js",
      "default": "./dist/adapters/express/index.js"
    },
    "./adapters/fastify": {
      "import": "./dist/adapters/fastify/index.mjs",
      "require": "./dist/adapters/fastify/index.js",
      "default": "./dist/adapters/fastify/index.js"
    },
    "./adapters/hono": {
      "import": "./dist/adapters/hono/index.mjs",
      "require": "./dist/adapters/hono/index.js",
      "default": "./dist/adapters/hono/index.js"
    },
    "./adapters/next/app": {
      "import": "./dist/adapters/next/app/index.mjs",
      "require": "./dist/adapters/next/app/index.js",
      "default": "./dist/adapters/next/app/index.js"
    },
    "./adapters/next/pages": {
      "import": "./dist/adapters/next/pages/index.mjs",
      "require": "./dist/adapters/next/pages/index.js",
      "default": "./dist/adapters/next/pages/index.js"
    },
    "./adapters/remix": {
      "import": "./dist/adapters/remix/index.mjs",
      "require": "./dist/adapters/remix/index.js",
      "default": "./dist/adapters/remix/index.js"
    },
    "./adapters/start": {
      "import": "./dist/adapters/start/index.mjs",
      "require": "./dist/adapters/start/index.js",
      "default": "./dist/adapters/start/index.js"
    },
    "./core": {
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./providers/aws": {
      "import": "./dist/providers/aws/index.mjs",
      "require": "./dist/providers/aws/index.js",
      "default": "./dist/providers/aws/index.js"
    },
    "./providers/azure": {
      "import": "./dist/providers/azure/index.mjs",
      "require": "./dist/providers/azure/index.js",
      "default": "./dist/providers/azure/index.js"
    },
    "./providers/edgestore": {
      "import": "./dist/providers/edgestore/index.mjs",
      "require": "./dist/providers/edgestore/index.js",
      "default": "./dist/providers/edgestore/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "package.json",
    "adapters",
    "core",
    "providers",
    "!**/*.test.*",
    "!**/__tests__"
  ],
  "dependencies": {
    "@edgestore/shared": "0.7.0",
    "@panva/hkdf": "^1.2.1",
    "cookie": "^0.7.2",
    "jose": "^4.15.9"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3.0.0",
    "@aws-sdk/s3-request-presigner": ">=3.0.0",
    "@azure/storage-blob": "^12.17.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "@azure/storage-blob": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1092.0",
    "@aws-sdk/s3-request-presigner": "^3.1092.0",
    "@azure/storage-blob": "^12.33.0",
    "@types/express": "^5.0.6",
    "@types/node": "25.0.3",
    "astro": "^5.18.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fastify": "^5.10.0",
    "hono": "^4.12.31",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "zod": "3.25.76"
  },
  "gitHead": "a223c4cb8df50e6b64f9db5dc2daf93848748da9"
}
