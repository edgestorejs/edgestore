{
  "name": "root",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build --filter=@edgestore/*",
    "build:all": "turbo run build",
    "watch": "turbo run watch --parallel",
    "dev": "turbo run dev --parallel --filter=next-basic --filter=@edgestore/*",
    "advanced:dev": "turbo run dev --parallel --filter=next-advanced --filter=@edgestore/*",
    "express:dev": "turbo run dev --parallel --filter=express-basic --filter=@edgestore/*",
    "vite-express:dev": "turbo run dev --parallel --filter=vite-basic --filter=express-basic --filter=@edgestore/*",
    "fastify:dev": "turbo run dev --parallel --filter=fastify-basic --filter=@edgestore/*",
    "vite-fastify:dev": "turbo run dev --parallel --filter=vite-basic --filter=fastify-basic --filter=@edgestore/*",
    "hono:dev": "turbo run dev --parallel --filter=hono-basic --filter=@edgestore/*",
    "vite-hono:dev": "turbo run dev --parallel --filter=vite-basic --filter=hono-basic --filter=@edgestore/*",
    "remix:dev": "turbo run dev --parallel --filter=remix-basic --filter=@edgestore/*",
    "astro:dev": "turbo run dev --parallel --filter=astro-basic --filter=@edgestore/*",
    "aws:dev": "turbo run dev --parallel --filter=next-basic-aws --filter=@edgestore/*",
    "packages:dev": "turbo run dev --parallel --filter=@edgestore/*",
    "components:dev": "turbo run dev --parallel --filter=components --filter=@edgestore/*",
    "basic-access-control:dev": "turbo run dev --parallel --filter=basic-access-control --filter=@edgestore/*",
    "start-basic:dev": "turbo run dev --parallel --filter=start-basic --filter=@edgestore/*",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm build && pnpm --filter docs run build",
    "test": "turbo run test --filter=@edgestore/*",
    "test:types": "turbo run test:types --filter=edgestore-tests",
    "test:smoke": "turbo run test:smoke --filter=@edgestore/server",
    "lint": "turbo lint",
    "typecheck": "turbo run typecheck --filter=@edgestore/*",
    "lint-fix": "turbo lint -- --fix && manypkg fix && pnpm format:write",
    "format": "prettier \"**/*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,css}\"",
    "format:write": "pnpm format --write --list-different",
    "clean": "find . -name node_modules -o -name .turbo -o -name .next -o -name dist -type d -prune | xargs rm -rf",
    "registry:build": "shadcn build --output=docs/public/r",
    "changeset": "changeset",
    "version": "changeset version && pnpm -s sync-versions",
    "release": "pnpm build && changeset publish",
    "sync-versions": "tsx scripts/syncVersions.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.1",
    "@eslint-react/eslint-plugin": "5.17.3",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@manypkg/cli": "^0.25.1",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-turbo": "2.10.5",
    "eslint-plugin-unicorn": "72.0.0",
    "prettier": "3.9.6",
    "prettier-plugin-tailwindcss": "0.8.1",
    "rollup": "4.62.2",
    "rollup-plugin-node-externals": "9.0.1",
    "rollup-plugin-swc3": "0.12.1",
    "shadcn": "4.13.1",
    "tsd": "^0.33.0",
    "tsx": "4.23.1",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "^4.1.10"
  }
}
